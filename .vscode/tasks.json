{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Frontend Dev",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/gamesales-web"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Backend Dev",
      "type": "shell",
      "command": "source ${workspaceFolder}/.venv/bin/activate && uvicorn app:app --reload --host 0.0.0.0 --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/api",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Run Frontend + Backend",
      "dependsOn": [
        "Backend Dev",
        "Frontend Dev"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
